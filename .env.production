NODE_ENV=production
PORT=5000
HOST=0.0.0.0

MONGO_URI=mongodb://mongo:27017/cine-stream

FRONTEND_URL=https://your-app.example.com
CORS_ORIGINS=https://your-app.example.com

JWT_SECRET=replace-with-long-production-secret
JWT_EXPIRES_IN=15m
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@your-app.example.com
ADMIN_PASSWORD=replace-with-strong-production-admin-password

LOG_LEVEL=info
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_MS=10000
