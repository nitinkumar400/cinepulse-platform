# =========================================
# CINE STREAM - Production Environment
# For Vercel Deployment
# =========================================

NODE_ENV=production

# For Vercel, PORT is set automatically - don't change
# PORT=5000
# HOST=0.0.0.0

# =========================================
# DATABASE - MongoDB Atlas (Required for Vercel)
# =========================================
# Get your free MongoDB Atlas cluster at:
# https://www.mongodb.com/cloud/atlas
#
# Format: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/DB_NAME
# MONGO_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/cinestream?retryWrites=true&w=majority

# =========================================
# FRONTEND URL - Update with your Vercel domain
# =========================================
FRONTEND_URL=https://your-vercel-app.vercel.app
CORS_ORIGINS=https://your-vercel-app.vercel.app

# =========================================
# SECURITY - Generate strong secrets
# =========================================
JWT_SECRET=your-super-secure-jwt-secret-change-this
JWT_EXPIRES_IN=7d

# =========================================
# ADMIN ACCOUNT - Change for production
# =========================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@cinestream.local
ADMIN_PASSWORD=Admin@12345

# =========================================
# EXTERNAL SERVICES
# =========================================
# Get your API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Optional: AI features (Ollama - local only, not for Vercel)
# OLLAMA_URL=http://127.0.0.1:11434/api/generate
# OLLAMA_MODEL=llama3
# OLLAMA_TIMEOUT_MS=10000

# =========================================
# LOGGING
# =========================================
LOG_LEVEL=info
