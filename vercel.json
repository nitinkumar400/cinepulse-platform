{
  "version": 2,
  "buildCommand": "npm run check",
  "installCommand": "npm install",
  "framework": null,
  "outputDirectory": "public",
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    { "source": "/",                      "destination": "/pages/index.html" },
    { "source": "/login",                 "destination": "/pages/login.html" },
    { "source": "/search",                "destination": "/pages/search.html" },
    { "source": "/dashboard",             "destination": "/pages/dashboard.html" },
    { "source": "/profile",               "destination": "/pages/profile.html" },
    { "source": "/admin",                 "destination": "/pages/admin.html" },
    { "source": "/watch/movie/:id",       "destination": "/pages/movie-details.html?id=:id" },
    { "source": "/watch/series/:id",      "destination": "/pages/movie-details.html?id=:id" },
    { "source": "/watch/anime/:id",       "destination": "/pages/movie-details.html?id=:id" },
    { "source": "/watch/tv/:id",          "destination": "/pages/movie-details.html?id=:id" },
    { "source": "/watch/documentary/:id", "destination": "/pages/movie-details.html?id=:id" },
    { "source": "/watch/cartoon/:id",     "destination": "/pages/movie-details.html?id=:id" },
    { "source": "/watch/:id",             "destination": "/pages/movie-details.html?id=:id" },
    { "source": "/browse/:category",      "destination": "/pages/browse.html" },
    { "source": "/api/(.*)",              "destination": "/api/server.js" },
    { "source": "/health",                "destination": "/api/server.js" },
    { "source": "/sitemap.xml",           "destination": "/api/server.js" }
  ],
  "crons": [
    { "path": "/api/sync",                       "schedule": "0 3 * * *" },
    { "path": "/api/sync/anime",                 "schedule": "30 3 * * *" },
    { "path": "/api/admin/servers/health/run",   "schedule": "0 4 * * *" }
  ],
  "headers": [
    {
      "source": "/pages/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "DEPLOY_TIMESTAMP": "2026-05-16T18:00:00Z"
  }
}
