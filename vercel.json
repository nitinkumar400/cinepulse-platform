{
  "version": 2,
  "buildCommand": "npm run check",
  "installCommand": "npm install",
  "framework": null,
  "outputDirectory": "public",
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/login",
      "destination": "/pages/login.html"
    },
    {
      "source": "/search",
      "destination": "/pages/search.html"
    },
    {
      "source": "/dashboard",
      "destination": "/pages/dashboard.html"
    },
    {
      "source": "/profile",
      "destination": "/pages/profile.html"
    },
    {
      "source": "/admin",
      "destination": "/pages/admin.html"
    },
    {
      "comment": "Clean watch URLs — SEO-friendly canonical paths for every media type",
      "source": "/watch/movie/:id",
      "destination": "/pages/movie-details.html?id=:id"
    },
    {
      "source": "/watch/series/:id",
      "destination": "/pages/movie-details.html?id=:id"
    },
    {
      "source": "/watch/anime/:id",
      "destination": "/pages/movie-details.html?id=:id"
    },
    {
      "source": "/watch/tv/:id",
      "destination": "/pages/movie-details.html?id=:id"
    },
    {
      "source": "/watch/documentary/:id",
      "destination": "/pages/movie-details.html?id=:id"
    },
    {
      "source": "/watch/cartoon/:id",
      "destination": "/pages/movie-details.html?id=:id"
    },
    {
      "comment": "Generic /watch/:id fallback — handles any category not listed above",
      "source": "/watch/:id",
      "destination": "/pages/movie-details.html?id=:id"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/health",
      "destination": "/api/server.js"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/sync/anime",
      "schedule": "30 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
