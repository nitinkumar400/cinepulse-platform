{
  "version": 2,
  "outputDirectory": "frontend",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/server.js"
    },
    {
      "source": "/health",
      "destination": "/backend/server.js"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
