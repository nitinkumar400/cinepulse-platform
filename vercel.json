{
  "version": 2,
  "buildCommand": "npm run check",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "backend/uploads/**"
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/server.js"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/server.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
