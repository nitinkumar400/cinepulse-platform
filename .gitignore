# Dependencies
node_modules/

# Environment variables - NEVER commit secrets
.env
.env.local
.env.*.local

# Uploaded files - too large for git
backend/uploads/videos/*
backend/uploads/thumbnails/*

# Keep the folders but not the files
!backend/uploads/videos/.gitkeep
!backend/uploads/thumbnails/.gitkeep

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-error.log*

# Build
dist/
build/
