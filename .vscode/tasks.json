{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "npm: install",
			"type": "shell",
			"command": "npm.cmd install",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "npm: dev",
			"type": "shell",
			"command": "npm.cmd run dev",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "npm: start",
			"type": "shell",
			"command": "npm.cmd start",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "Create Admin User",
			"type": "shell",
			"command": "node backend/scripts/createAdminUser.js",
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		}
	]
}