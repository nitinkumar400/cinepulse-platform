NODE_ENV=development
PORT=5001
HOST=0.0.0.0

MONGO_URI=mongodb://127.0.0.1:27017/cine-stream

FRONTEND_URL=http://localhost:5001
CORS_ORIGINS=http://localhost:5001,http://127.0.0.1:5001

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@cinestream.local
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# ===================
# Cron Security
# Used by Vercel Cron (and any external scheduler) to authenticate
# POST /api/sync and POST /api/sync/anime without a user JWT.
# Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
# Set the same value in Vercel Dashboard → Settings → Environment Variables.
# ===================
CRON_SECRET=replace-with-a-random-secret-min-32-chars

TMDB_API_KEY=your-tmdb-api-key
TMDB_READ_ACCESS_TOKEN=your-tmdb-read-access-token
ANILIST_CLIENT_ID=your-anilist-client-id
ANILIST_CLIENT_SECRET=your-anilist-client-secret

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

OPENSUB_API_KEY=your-opensubtitles-api-key

LOG_LEVEL=info
SOURCE_HEALTH_TIMEOUT_MS=7000
SOURCE_HEALTH_BATCH_SIZE=100
SOURCE_HEALTH_MAX_ERRORS=500

OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_MS=10000

# CinePro Microservice Integration
CINEPRO_URL=http://localhost:3000
